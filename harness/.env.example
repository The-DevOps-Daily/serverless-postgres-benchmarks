# Neon API key (https://console.neon.tech/app/settings/api-keys)
NEON_API_KEY=

# Supabase personal access token (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=
# Organization the harness creates bench projects in. Use a dedicated org:
# the free plan allows only 2 active projects, so don't share it with real apps.
SUPABASE_ORG_ID=

# Supabase signs database certs with its own CA. Download it from the
# dashboard (Database settings -> SSL certificate) for full TLS verification.
SUPABASE_DB_CA=./supabase-ca.crt

# Region pinning. Both must be the same physical region for fair numbers.
NEON_REGION=aws-eu-central-1
SUPABASE_REGION=eu-central-1

# Where this client is running, recorded in results metadata (e.g. fra1-droplet, raspberry-pi-sofia)
CLIENT_LOCATION=

# Plan/tier labels recorded in results metadata (e.g. free, launch, pro)
NEON_PLAN=free
SUPABASE_PLAN=free
